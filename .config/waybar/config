{
  "layer": "top",
  "position": "top",
  "height": 28,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["network", "bluetooth", "pulseaudio", "tray"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "format": "{name}"
  },

  "clock": {
    "format": "{:%a %b %d  %I:%M %p}",
    "tooltip-format": "{:%A, %B %d, %Y}",
    "on-click": "kitty --class floating-clock -e cal"
  },

  "network": {
    "format-wifi": "󰖩",
    "format-ethernet": "󰈀",
    "format-disconnected": "󰖪",
    "tooltip-format": "{ipaddr}",
    "on-click": "nm-connection-editor"
  },

  "bluetooth": {
    "format": "",
    "format-disabled": "",
    "format-off": "",
    "on-click": "blueman-manager"
  },

  "pulseaudio": {
    "format": "{icon}",
    "format-muted": "󰝟",
    "format-icons": ["", "", ""],
    "on-click": "pavucontrol"
  },

  "tray": {
    "spacing": 10
  }
}
